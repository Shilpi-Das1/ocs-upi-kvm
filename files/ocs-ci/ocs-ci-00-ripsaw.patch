+
+            log.info(f"Patching pgbench for ppc64le in {pgbench_defaults_dir}")
+            run("sed -i 's|quay.io/cloud-bulldozer/pgbench:latest|quay.io/multi-arch/cloud-bulldozer:pgbench|g' main.yml", shell=True, check=True, cwd=pgbench_defaults_dir)
